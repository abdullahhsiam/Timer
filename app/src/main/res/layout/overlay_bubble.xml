<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- 1. COLLAPSED VIEW: A small, glowing, compact circular bubble -->
    <LinearLayout
        android:id="@+id/collapsed_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/timer_widget_bg"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="visible">

        <!-- Glowing active dot -->
        <View
            android:id="@+id/collapsed_glowing_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"
            android:background="@drawable/active_dot_bg" />

        <TextView
            android:id="@+id/collapsed_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="00:00"
            android:textColor="@color/purple_glow"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2. EXPANDED VIEW: Complete glassmorphic card with rich interactive control buttons -->
    <LinearLayout
        android:id="@+id/expanded_container"
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:background="@drawable/timer_widget_bg"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <!-- Top Header Info row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/expanded_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:text="ACTIVE TIMER"
                android:textColor="@color/purple_glow"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/btn_close_overlay"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />
        </RelativeLayout>

        <!-- Dynamic Timing Value Display -->
        <TextView
            android:id="@+id/expanded_time_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            android:text="00:00"
            android:textColor="@color/off_white"
            android:textSize="28sp" />

        <!-- Control Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_overlay_pause_play"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/timer_widget_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:text="Pause"
                android:textColor="@color/purple_glow"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btn_overlay_add_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/timer_widget_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:text="+1m"
                android:textColor="@color/cyan_glow"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btn_overlay_reset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/timer_widget_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:text="Reset"
                android:textColor="@color/off_white"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
