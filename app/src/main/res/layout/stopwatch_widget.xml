<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/stopwatch_widget_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_stopwatch_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.15"
        android:text="STOPWATCH"
        android:textColor="@color/neon_pink"
        android:shadowColor="#CC000000"
        android:shadowDx="1.5"
        android:shadowDy="1.5"
        android:shadowRadius="2"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_stopwatch_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-light"
        android:text="00:00.00"
        android:textColor="@color/off_white"
        android:shadowColor="#E4000000"
        android:shadowDx="1.5"
        android:shadowDy="1.5"
        android:shadowRadius="3.5"
        android:textSize="28sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_widget_stopwatch_toggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_stopwatch"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="Play"
            android:textColor="@color/neon_pink"
            android:shadowColor="#CC000000"
            android:shadowDx="1.0"
            android:shadowDy="1.0"
            android:shadowRadius="1.5"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btn_widget_stopwatch_reset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_stopwatch"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="Reset"
            android:textColor="@color/off_white"
            android:shadowColor="#CC000000"
            android:shadowDx="1.0"
            android:shadowDy="1.0"
            android:shadowRadius="1.5"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />
    </LinearLayout>
</LinearLayout>

