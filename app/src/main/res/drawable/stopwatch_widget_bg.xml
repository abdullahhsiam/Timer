<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 0: Elegant Soft Dark Drop-Shadow -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#3B000000" />
        </shape>
    </item>

    <!-- Layer 1: "Fluidy Gradienty" Glowing Outer Border -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF00E6FF"
                android:centerColor="#FFFF5282"
                android:endColor="#FFFF2A6D"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Layer 2: Frosted Translucent Acrylic Glass Backdrop -->
    <item
        android:left="2.5dp"
        android:top="2.5dp"
        android:right="4.5dp"
        android:bottom="4.5dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#B20A0914"
                android:centerColor="#9E14091A"
                android:endColor="#B21E0922"
                android:type="linear" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>


